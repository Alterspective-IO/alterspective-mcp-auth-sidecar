# Sidecar listens on this port (public side)
SIDECAR_PORT=4000

# Identifies this MCP server. The required scope on every PAT is `mcp:<slug>`.
# Examples: ms365, sharedo, cortex, vault, prompts, brand, present, timely, monday, bloomgrowth, docs
MCP_SERVER_SLUG=cortex

# Where the sidecar forwards authenticated requests. Should be localhost-bound.
MCP_UPSTREAM_URL=http://127.0.0.1:3001

# Keystone base URL (no trailing slash)
KEYSTONE_URL=https://identity.alterspective.com.au

# Service token issued by Keystone with `auth:introspect` scope
KEYSTONE_SERVICE_TOKEN=

# NOTE: There is no REQUIRES_ADMIN env var.
# Privileged-scope enforcement (e.g. mcp:vault) happens at PAT *issuance*
# in Keystone via self_service_scopes.requires_admin (migration 010).
# If a scope is in the PAT, the user already passed the admin gate.

# CORS — comma-separated. Empty means no cross-origin allowed.
ALLOWED_ORIGINS=

# Cache tuning
INTROSPECT_CACHE_TTL_MS=60000
INTROSPECT_NEGATIVE_CACHE_TTL_MS=10000

# Audit batching
AUDIT_BATCH_SIZE=20
AUDIT_FLUSH_INTERVAL_MS=5000

# Local dev only — refuses to start in production. Skips Keystone introspection.
# MOCK_AUTH_OID=00000000-0000-0000-0000-000000000000
# MOCK_AUTH_EMAIL=dev@alterspective.com.au
